# Пример файла конфигурации .env
# Скопируйте этот файл в .env и заполните значения

# Токен бота от @BotFather
token_bot=YOUR_BOT_TOKEN_HERE

# ID канала для хранения медиафайлов (фото/видео)
# Этот канал используется для долговременного хранения файлов
# Формат: -100XXXXXXXXXX (для приватных каналов) или @channelname (для публичных)
# ВАЖНО: Бот должен быть администратором в этом канале!
MEDIA_STORAGE_CHANNEL_ID=-1001234567890
